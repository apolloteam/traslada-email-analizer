CLIENT_ID=...
CLIENT_SECRET=...
TENANT_ID=...
BUZONES=email1@dominio.com;email2@dominio.com
ANTHROPIC_API_KEY=...
AI_MODEL=claude-sonnet-4-6
# Precios USD por 1M de tokens del modelo configurado en AI_MODEL.
# Si cambiás AI_MODEL, actualizá estos importes.
AI_INPUT_PRICE_PER_1M=3.00
AI_OUTPUT_PRICE_PER_1M=15.00
INTERVALO_MINUTOS=1
MAX_CORREOS_POR_CICLO=10
LOG_API_BASE_URL=https://api.traslada.com.ar
# Opcional. Fecha/hora ISO 8601 en UTC desde la cual procesar correos (go-live del agente).
# Evita procesar correos viejos al arrancar en un buzón sin la categoría 'AgenteProcesado'.
# Si se deja vacía/sin definir, se procesan todos los no procesados sin importar la fecha.
PROCESAR_DESDE=2026-06-11T00:00:00Z
# Remitente del formulario web que genera leads (distinto en dev y prod).
# Si se deja vacío, la detección de leads de formulario queda desactivada.
REMITENTE_LEAD=noreply@traslada.com # Dev: backup@traslada.com.ar | Prod: noreply@traslada.com.ar